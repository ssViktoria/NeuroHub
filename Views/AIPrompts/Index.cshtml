@model IEnumerable<NeuroHub.Models.AIPrompt>

@{
    ViewData["Title"] = "AI Prompts";
}

<h1>Бібліотека AI промптів</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Створити новий промпт</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Назва</th>
            <th>Нейромережа</th>
            <th>Ціна</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.NeuralNetwork</td>
                <td>@(item.Price == 0 ? "Безкоштовно" : item.Price + " грн")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>