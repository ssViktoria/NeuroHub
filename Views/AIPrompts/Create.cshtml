@model NeuroHub.Models.AIPrompt

@{
    ViewData["Title"] = "Create Prompt";
}

<div class="text-center mb-4">
    <h1 style="background: linear-gradient(135deg, #f0abfc, #db2777); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: bold;">
        <i class="fas fa-plus-circle me-2"></i>Створити новий промпт
    </h1>
    <p class="text-muted" style="color: #a855f7 !important;">
        <i class="fas fa-magic me-1"></i>
        Заповніть форму для створення унікального AI промпту
        <i class="fas fa-magic ms-1"></i>
    </p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div style="background: white; border-radius: 25px; padding: 2rem; box-shadow: 0 15px 40px rgba(0,0,0,0.15); transition: transform 0.3s ease;">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius: 15px;"></div>

                <div class="form-group mb-4">
                    <label asp-for="Title" class="control-label" style="color: #c026d3; font-weight: bold; margin-bottom: 8px;">
                        <i class="fas fa-tag me-2"></i>Назва промпту
                    </label>
                    <input asp-for="Title" class="form-control" placeholder="Наприклад: Генерація SEO статті"
                           style="border-radius: 12px; border: 2px solid #f0abfc; padding: 12px; transition: all 0.3s ease;" />
                    <span asp-validation-for="Title" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="PromptText" class="control-label" style="color: #c026d3; font-weight: bold; margin-bottom: 8px;">
                        <i class="fas fa-file-alt me-2"></i>Текст промпту
                    </label>
                    <textarea asp-for="PromptText" class="form-control" rows="6"
                              placeholder="Введіть текст вашого промпту тут..."
                              style="border-radius: 12px; border: 2px solid #f0abfc; padding: 12px; resize: vertical;"></textarea>
                    <span asp-validation-for="PromptText" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="NeuralNetwork" class="control-label" style="color: #c026d3; font-weight: bold; margin-bottom: 8px;">
                        <i class="fas fa-microchip me-2"></i>Нейромережа
                    </label>
                    <select asp-for="NeuralNetwork" class="form-control"
                            style="border-radius: 12px; border: 2px solid #f0abfc; padding: 12px; cursor: pointer;">
                        <option value="ChatGPT">🤖 ChatGPT</option>
                        <option value="Midjourney">🎨 Midjourney</option>
                        <option value="StableDiffusion">🧠 StableDiffusion</option>
                    </select>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Price" class="control-label" style="color: #c026d3; font-weight: bold; margin-bottom: 8px;">
                        <i class="fas fa-coins me-2"></i>Ціна (грн)
                    </label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01"
                           placeholder="0 - безкоштовно"
                           style="border-radius: 12px; border: 2px solid #f0abfc; padding: 12px;" />
                    <small class="text-muted" style="color: #a855f7 !important;">
                        <i class="fas fa-info-circle me-1"></i>Введіть 0 для безкоштовних промптів
                    </small>
                </div>

                <div class="form-group text-center mt-5">
                    <button type="submit" class="btn" style="background: linear-gradient(135deg, #c026d3, #db2777); border: none; color: white; border-radius: 30px; padding: 12px 35px; font-weight: bold; margin-right: 15px; transition: all 0.3s ease;">
                        <i class="fas fa-save me-2"></i>Створити промпт
                    </button>
                    <a asp-action="Index" class="btn" style="background: #6b7280; color: white; border-radius: 30px; padding: 12px 35px; font-weight: bold; transition: all 0.3s ease; text-decoration: none;">
                        <i class="fas fa-arrow-left me-2"></i>Назад до списку
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Ефекти при фокусі */
    input:focus, textarea:focus, select:focus {
        border-color: #c026d3 !important;
        box-shadow: 0 0 0 0.2rem rgba(192, 38, 211, 0.25) !important;
        outline: none;
    }

    /* Ефект при наведенні на кнопки */
    .btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
    }

    button[type="submit"]:hover {
        background: linear-gradient(135deg, #a21caf, #be185d) !important;
    }

    a[style*="background: #6b7280"]:hover {
        background: #4b5563 !important;
    }

    /* Анімація для форми */
    .row.justify-content-center > div > div {
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}